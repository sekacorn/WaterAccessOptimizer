# Copy this file to `.env` and replace placeholder values before running the full stack.

# Required secrets
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-with-at-least-32-characters
GRAFANA_PASSWORD=change-me

# Database defaults
POSTGRES_DB=wateroptimizer
POSTGRES_USER=wateradmin

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Frontend runtime endpoints used by the containerized frontend
VITE_API_BASE_URL=http://data-service:8087/api/v1
VITE_AUTH_API_URL=http://auth-service:8081/api/v1/auth

# Optional demo-mode flags for local frontend-only work
VITE_ENABLE_MOCK_API=false
VITE_AUTO_LOGIN_DEMO=false
