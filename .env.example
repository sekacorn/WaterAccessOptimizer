# Environment Variables for WaterAccessOptimizer
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_PASSWORD=your-secure-password-here
POSTGRES_DB=wateraccess
POSTGRES_USER=wateradmin

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_EXPIRATION=3600000

# LLM Service Configuration
LLM_API_KEY=your-llm-api-key-here
LLM_API_URL=https://api.openai.com/v1

# Redis Configuration
REDIS_PASSWORD=

# Application URLs
APP_URL=http://localhost:8080
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8085

# Environment
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# SSO Configuration (Optional - configure per enterprise via UI)
# These are default/fallback values if needed
SSO_ENABLED=false
SSO_CALLBACK_URL=${APP_URL}/api/auth/sso/callback
SSO_METADATA_URL=${APP_URL}/api/auth/sso/metadata
