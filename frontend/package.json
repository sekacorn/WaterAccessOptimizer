{
  "name": "water-access-optimizer-frontend",
  "version": "1.0.0",
  "description": "React frontend for WaterAccessOptimizer with uploads, mapping, and risk assessment workflows",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.js --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
